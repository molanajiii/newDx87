# PlayBeat Digital — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it contains secrets!

# ── BACKEND API CONFIGURATION ────────────────────────────
# Your Render.com backend URL
REACT_APP_API_URL=https://playbeat-backend.onrender.com

# ── SERVER CONFIGURATION ─────────────────────────────────
# Node.js environment
NODE_ENV=production

# Server port (Vercel will override this)
PORT=3000

# ── AUTHENTICATION ───────────────────────────────────────
# JWT Secret (if using JWT auth)
REACT_APP_JWT_SECRET=your_jwt_secret_here_change_this

# API Key for backend (if applicable)
REACT_APP_API_KEY=your_api_key_here_change_this

# ── VERCEL DEPLOYMENT ────────────────────────────────────
# Your Vercel URL (auto-set by Vercel)
VERCEL_URL=playbeat.vercel.app

# ── LOGGING & MONITORING ────────────────────────────────
# Optional: Error tracking
SENTRY_DSN=

# ── FEATURE FLAGS ────────────────────────────────────────
# Enable debug mode
DEBUG=false

# ── DATABASE (if frontend needs direct DB access) ───────
# Not recommended - use backend API instead
DATABASE_URL=

# ────────────────────────────────────────────────────────
# IMPORTANT NOTES:
# 1. REACT_APP_API_URL must match your Render backend URL
# 2. Backend must have CORS enabled for your Vercel domain
# 3. Never commit .env file to version control
# 4. Update in Vercel dashboard: Settings → Environment Variables
# ────────────────────────────────────────────────────────
